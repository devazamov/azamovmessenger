# Firebase config — Firebase Console > Project settings > Web app dan oling.
# Bu faylni nusxalab .env qiling va qiymatlarni to'ldiring.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Supabase — media (rasm/video/ovoz/story) saqlash uchun.
# Supabase Dashboard > Project Settings > API dan oling.
# Bo'sh qoldirilsa, media Firebase Storage'ga saqlanadi (fallback).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=media
